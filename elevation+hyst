import numpy as np
import matplotlib.pyplot as plt

class SimulationConfig: 
    def __init__(self, ho_strategy='SNR', num_satellites=35, hysteresis_dB=0.0):
        self.calculate_interference = False 
        self.moving_user = False  
        self.ho_strategy = ho_strategy
        self.N = num_satellites  
        
        # Logika konfiguracije na osnovu izabrane strategije
        if ho_strategy == 'SNR':
            self.H_dB = hysteresis_dB
            self.use_hysteresis = True if hysteresis_dB > 0 else False
            self.alpha_off = 0.0
        elif ho_strategy == 'elevation_based':
            self.H_dB = 0.0
            self.use_hysteresis = False
            self.alpha_off = 2.0  # Ofset od 2 stepena za Elevation
            
        self.gamma_th_dB = 3.0     # Outage prag [dB]
        self.elev_min_deg = 10.0    
        self.Re = 6371e3            
        self.h = 600e3  
        self.r_orbit = self.Re + self.h
        self.konstanta_mi = 3.986e14

        # Vreme simulacije
        self.dt = 0.5          
        
        # Link Budget parametri
        self.fc = 2e9               
        self.c = 3e8                
        self.lambda_ = self.c / self.fc
        self.Pt_dBm = 35.0          
        self.Gt_dBi = 26.0          
        self.Gr_max_dBi = 0.0      
        self.La = 0.5
        
        self.B = 10e6                
        self.N0_dBmHz = -174.0
        self.NF_dB = 4.0

        self.noise_dBm = self.N0_dBmHz + 10 * np.log10(self.B) + self.NF_dB
        self.noise_linear = 10 ** (self.noise_dBm / 10.0) 

        # Kašnjenje usled hendovera (40 ms)
        self.handover_penalty_seconds = 0.04  

    @property
    def omega(self):
        return np.sqrt(self.konstanta_mi / (self.r_orbit ** 3))

    @property
    def T_orbite(self): 
        return 2 * np.pi / self.omega


class User:
    def __init__(self, angle_rad=0.0, radius=6371e3):
        self.radius = radius 
        self.v_ms = 100 / 3.6   
        self.omega_user = self.v_ms / self.radius 
        self.angle = angle_rad
        self.x = radius * np.cos(angle_rad)
        self.y = radius * np.sin(angle_rad)
        self.ux = self.x / radius
        self.uy = self.y / radius


class Satellite:
    def __init__(self, sat_id, initial_theta):
        self.id = sat_id
        self.initial_theta = initial_theta
        self.metrics_history = {}     
        self.positions_history = {}   
        self.prev_sf_LoS = None 
        self.prev_sf_NLoS = None

    def get_3gpp_rural_parameters(self, elev_deg):
        if elev_deg <= 15.0:
            return 0.782, 1.14, 9.7, 18.2
        elif elev_deg <= 25.0:
            return 0.861, 0.92, 8.8, 15.9
        else:
            return 0.950, 0.72, 7.5, 0.0

    def update_position_and_metrics(self, t, config, user): 
        theta_orbit = self.initial_theta + config.omega * t
        xs = config.r_orbit * np.cos(theta_orbit)
        ys = config.r_orbit * np.sin(theta_orbit)
        
        self.positions_history[t] = (xs, ys)
        
        dx = xs - user.x
        dy = ys - user.y
        d = np.sqrt(dx**2 + dy**2)
        
        elev_rad = np.arcsin((dx * user.ux + dy * user.uy) / d)
        elev_deg = np.degrees(elev_rad)
        
        if elev_deg >= config.elev_min_deg:
            visible = True
            fspl_dB = 20 * np.log10(4 * np.pi * d * config.fc / config.c) 
            pr_los, sigma_los, sigma_nlos, cl_dB = self.get_3gpp_rural_parameters(elev_deg)
            
            novi_sum_los = np.random.normal(0, sigma_los)
            novi_sum_nlos = np.random.normal(0, sigma_nlos)
            
            rho = 0.98
            if self.prev_sf_LoS is None or self.prev_sf_NLoS is None:
                sf_los = novi_sum_los
                sf_nlos = novi_sum_nlos
            else:
                sf_los = rho * self.prev_sf_LoS + np.sqrt(1 - rho**2) * novi_sum_los
                sf_nlos = rho * self.prev_sf_NLoS + np.sqrt(1 - rho**2) * novi_sum_nlos
                
            self.prev_sf_LoS = sf_los
            self.prev_sf_NLoS = sf_nlos
            
            PL_LoS = sf_los + fspl_dB
            PL_NLoS = sf_nlos + cl_dB + fspl_dB
            PL_tot = pr_los * PL_LoS + (1.0 - pr_los) * PL_NLoS
            pr_dBm = config.Pt_dBm + config.Gt_dBi + config.Gr_max_dBi - PL_tot - config.La
        else:
            visible = False
            pr_dBm = -np.inf
            self.prev_sf_LoS = None
            self.prev_sf_NLoS = None
            
        self.metrics_history[t] = {
            'sinr_dB': -np.inf,
            'capacity': 0.0,
            'visible': visible,
            'pr_dBm': pr_dBm,
            'distance': d if visible else np.inf, 
            'elevation_deg': elev_deg if visible else 0.0  
        }

    def calculate_sinr_and_interference(self, t, config):
        if not self.metrics_history[t]['visible']:
            return
        pr_linear = 10 ** (self.metrics_history[t]['pr_dBm'] / 10.0)
        sinr_linearno = pr_linear / config.noise_linear
        self.metrics_history[t]['sinr_dB'] = 10 * np.log10(sinr_linearno)
        self.metrics_history[t]['capacity'] = config.B * np.log2(1.0 + sinr_linearno)


def handover_decision(t, idx, current_serving_id, satellites, config):    
    current_sat = next((s for s in satellites if s.id == current_serving_id), None)
    
    # 1. Prinudni hendover (početak ili kada aktivni satelit zađe za horizont)
    if idx == 0 or current_serving_id == 0 or current_sat is None or not current_sat.metrics_history[t]['visible']:
        visible_sats = [s for s in satellites if s.metrics_history[t]['visible'] and s.metrics_history[t]['sinr_dB'] != -np.inf] 
        if not visible_sats:
            return 0 
        if config.ho_strategy == 'elevation_based':
            best_sat = max(visible_sats, key=lambda s: s.metrics_history[t]['elevation_deg'])
        else:
            best_sat = max(visible_sats, key=lambda s: s.metrics_history[t]['sinr_dB']) 
        return best_sat.id

    # 2. Evaluacija potencijalnog hendovera dok je trenutni satelit još aktivan
    current_sinr = current_sat.metrics_history[t]['sinr_dB']
    current_alpha = current_sat.metrics_history[t]['elevation_deg']
    
    best_sat_id = current_serving_id

    # --- STRATEGIJA: SNR sa Histerezisom ---
    if config.ho_strategy == 'SNR':
        max_threshold = current_sinr + config.H_dB if config.use_hysteresis else current_sinr
        
        for sat in satellites:
            if sat.id == current_serving_id or not sat.metrics_history[t]['visible']: 
                continue
            if sat.metrics_history[t]['sinr_dB'] > max_threshold:
                max_threshold = sat.metrics_history[t]['sinr_dB']
                best_sat_id = sat.id
                
    # --- STRATEGIJA: ELEVATION BASED ---
    elif config.ho_strategy == 'elevation_based':
        max_threshold = current_alpha + config.alpha_off
        
        for sat in satellites:
            if sat.id == current_serving_id or not sat.metrics_history[t]['visible']: 
                continue
            if sat.metrics_history[t]['elevation_deg'] > max_threshold:
                max_threshold = sat.metrics_history[t]['elevation_deg']
                best_sat_id = sat.id
              
    return best_sat_id


def run_core_simulation(ho_strategy, num_satellites, hysteresis_value=0.0):
    np.random.seed(42)  # Fiksirano za fer poređenje fedinga među algoritmima
    cfg = SimulationConfig(ho_strategy=ho_strategy, num_satellites=num_satellites, hysteresis_dB=hysteresis_value)
    user = User(angle_rad=0.0, radius=cfg.Re)
    
    satellites = [Satellite(sat_id=i, initial_theta=2 * np.pi * (i - 1) / cfg.N) for i in range(1, cfg.N + 1)]
        
    time_steps = []
    current_time = 0.0 
    while current_time <= cfg.T_orbite * 0.5: 
        time_steps.append(current_time)
        current_time += cfg.dt

    for t in time_steps:
        for sat in satellites:
            sat.update_position_and_metrics(t, cfg, user) 
            sat.calculate_sinr_and_interference(t, cfg)

    current_serving_id = 0
    handover_count = 0
    outage_points = 0
    capacity_accumulator = []
    delay_accumulator = []
    session_lengths = []
    current_session_steps = 0

    for idx, t in enumerate(time_steps):
        prev_serving_id = current_serving_id
        current_serving_id = handover_decision(t, idx, current_serving_id, satellites, cfg)
        
        is_handover_event = False
        if idx > 0 and current_serving_id != prev_serving_id and prev_serving_id != 0 and current_serving_id != 0:
            handover_count += 1
            is_handover_event = True

        if current_serving_id == 0:
            outage_points += 1
            capacity_accumulator.append(0.0)
            if current_session_steps > 0:
                session_lengths.append(current_session_steps * cfg.dt)
            current_session_steps = 0
        else:
            active_sat = next(s for s in satellites if s.id == current_serving_id) 
            sat_data = active_sat.metrics_history[t]
            
            if current_serving_id == prev_serving_id:
                current_session_steps += 1
            else:
                if current_session_steps > 0:
                    session_lengths.append(current_session_steps * cfg.dt)
                current_session_steps = 1
            
            if sat_data['sinr_dB'] < cfg.gamma_th_dB:
                outage_points += 1
                capacity_accumulator.append(0.0)
            else:
                capacity_accumulator.append(sat_data['capacity'] / 1e6) 
                
                prop_delay_ms = (2 * sat_data['distance'] / cfg.c) * 1000 
                ho_delay_ms = (cfg.handover_penalty_seconds * 1000) if is_handover_event else 0.0
                total_delay_ms = prop_delay_ms + ho_delay_ms
                delay_accumulator.append(total_delay_ms)

    if current_session_steps > 0:
        session_lengths.append(current_session_steps * cfg.dt)

    outage_prob = (outage_points / len(time_steps)) * 100 
    avg_capacity = np.mean(capacity_accumulator)
    avg_delay = np.mean(delay_accumulator) if delay_accumulator else 0.0
    max_delay = np.max(delay_accumulator) if delay_accumulator else 0.0
    avg_session_time = np.mean(session_lengths) if session_lengths else 0.0
    
    return handover_count, outage_prob, avg_capacity, avg_delay, max_delay, avg_session_time


def generate_comparative_plots():
    satellite_density_range = np.arange(20, 46, 5)
    
    # Inicijalizacija lista za tri SNR slučaja
    h_0_metrics = {m: [] for m in ['ho', 'out', 'cap', 'adel', 'mdel', 'sess']}
    h_1_metrics = {m: [] for m in ['ho', 'out', 'cap', 'adel', 'mdel', 'sess']}
    h_3_metrics = {m: [] for m in ['ho', 'out', 'cap', 'adel', 'mdel', 'sess']}
    # Inicijalizacija za referentni Elevation-based (offset = 2 deg)
    el_metrics = {m: [] for m in ['ho', 'out', 'cap', 'adel', 'mdel', 'sess']}

    print("Pokrećem simulaciju za analizu SNR histerezisa (H = 0, 1, 3 dB) vs Elevation...")
    
    for n_sats in satellite_density_range:
        print(f"Izvršavam proračune za N = {n_sats} satelita...")
        
        # 1. SNR sa H = 0.0 dB (čist SNR bez histerezisa)
        ho, out, cap, adel, mdel, sess = run_core_simulation('SNR', n_sats, hysteresis_value=0.0)
        h_0_metrics['ho'].append(ho); h_0_metrics['out'].append(out); h_0_metrics['cap'].append(cap)
        h_0_metrics['adel'].append(adel); h_0_metrics['mdel'].append(mdel); h_0_metrics['sess'].append(sess)
        
        # 3. SNR sa H = 3.0 dB
        ho, out, cap, adel, mdel, sess = run_core_simulation('SNR', n_sats, hysteresis_value=3.0)
        h_3_metrics['ho'].append(ho); h_3_metrics['out'].append(out); h_3_metrics['cap'].append(cap)
        h_3_metrics['adel'].append(adel); h_3_metrics['mdel'].append(mdel); h_3_metrics['sess'].append(sess)
        
        # 4. Referentni Elevation-based sa offsetom od 2.0 stepena
        ho, out, cap, adel, mdel, sess = run_core_simulation('elevation_based', n_sats)
        el_metrics['ho'].append(ho); el_metrics['out'].append(out); el_metrics['cap'].append(cap)
        el_metrics['adel'].append(adel); el_metrics['mdel'].append(mdel); el_metrics['sess'].append(sess)

    # Kreiranje 6 uporednih grafikona
    fig, axs = plt.subplots(3, 2, figsize=(14, 16), sharex=True)
    
    # Stilovi linija
    snr0_style = dict(marker='o', color='crimson', linewidth=2, label='SNR (H = 0 dB)')
    snr3_style = dict(marker='s', color='purple', linewidth=2, label='SNR (H = 3 dB)')
    elev_style = dict(marker='x', color='darkorange', linestyle='--', linewidth=2, label='Elevation-based (off = 2°)')

    # 1. Broj Hendovera
    axs[0, 0].plot(satellite_density_range, h_0_metrics['ho'], **snr0_style)
    axs[0, 0].plot(satellite_density_range, h_3_metrics['ho'], **snr3_style)
    axs[0, 0].plot(satellite_density_range, el_metrics['ho'], **elev_style)
    axs[0, 0].set_ylabel('Ukupan broj hendovera')
    axs[0, 0].grid(True, linestyle=':', alpha=0.6)
    axs[0, 0].legend()
    axs[0, 0].set_title('1. Ukupan broj izvršenih hendovera')

    # 2. Prosečan kapacitet
    axs[0, 1].plot(satellite_density_range, h_0_metrics['cap'], **snr0_style)
    axs[0, 1].plot(satellite_density_range, h_3_metrics['cap'], **snr3_style)
    axs[0, 1].plot(satellite_density_range, el_metrics['cap'], **elev_style)
    axs[0, 1].set_ylabel('Prosečan kapacitet [Mbps]')
    axs[0, 1].grid(True, linestyle=':', alpha=0.6)
    axs[0, 1].legend()
    axs[0, 1].set_title('2. Prosečan kapacitet sistema')

    # 3. Verovatnoća otkaza
    axs[1, 0].plot(satellite_density_range, h_0_metrics['out'], **snr0_style)

    axs[1, 0].plot(satellite_density_range, h_3_metrics['out'], **snr3_style)
    axs[1, 0].plot(satellite_density_range, el_metrics['out'], **elev_style)
    axs[1, 0].set_ylabel('Verovatnoća otkaza [%]')
    axs[1, 0].grid(True, linestyle=':', alpha=0.6)
    axs[1, 0].legend()
    axs[1, 0].set_title('3. Verovatnoća otkaza (Outage)')

    # 4. Prosečno kašnjenje
    axs[1, 1].plot(satellite_density_range, h_0_metrics['adel'], **snr0_style)
    axs[1, 1].plot(satellite_density_range, h_3_metrics['adel'], **snr3_style)
    axs[1, 1].plot(satellite_density_range, el_metrics['adel'], **elev_style)
    axs[1, 1].set_ylabel('Prosečno kašnjenje [ms]')
    axs[1, 1].grid(True, linestyle=':', alpha=0.6)
    axs[1, 1].legend()
    axs[1, 1].set_title('4. Prosečno kašnjenje (RTT + HO delay)')

    # 5. Maksimalno kašnjenje
    axs[2, 0].plot(satellite_density_range, h_0_metrics['mdel'], **snr0_style)
    axs[2, 0].plot(satellite_density_range, h_3_metrics['mdel'], **snr3_style)
    axs[2, 0].plot(satellite_density_range, el_metrics['mdel'], **elev_style)
    axs[2, 0].set_xlabel('Ukupan broj satelita (N)')
    axs[2, 0].set_ylabel('Maksimalno kašnjenje [ms]')
    axs[2, 0].grid(True, linestyle=':', alpha=0.6)
    axs[2, 0].legend()
    axs[2, 0].set_title('5. Maksimalno izmereno kašnjenje')

    # 6. Prosečno trajanje veze (Session Time)
    axs[2, 1].plot(satellite_density_range, h_0_metrics['sess'], **snr0_style)
    axs[2, 1].plot(satellite_density_range, h_3_metrics['sess'], **snr3_style)
    axs[2, 1].plot(satellite_density_range, el_metrics['sess'], **elev_style)
    axs[2, 1].set_xlabel('Ukupan broj satelita (N)')
    axs[2, 1].set_ylabel('Trajanje veze sa satelitom [s]')
    axs[2, 1].grid(True, linestyle=':', alpha=0.6)
    axs[2, 1].legend()
    axs[2, 1].set_title('6. Prosečno trajanje sesije po satelitu')

    plt.tight_layout()
    plt.show()

if __name__ == '__main__':
    generate_comparative_plots()